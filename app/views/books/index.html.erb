<div class="container mt-4">

  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="fw-bold">📚 Books</h1>
    <% if user_signed_in? %>
      <%= link_to "+ Publish New Book", new_book_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <!-- BOOK GRID -->
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">

    <% @books.each do |book| %>
      <div class="col">
        <div class="card h-100 shadow-sm d-flex flex-column">

          <!-- COVER IMAGE -->
          <% if book.cover_image.attached? %>
            <%= image_tag book.cover_image,
                class: "card-img-top",
                style: "height: 180px; object-fit: cover;" %>
          <% else %>
            <div class="bg-light text-center p-5 text-muted d-flex align-items-center justify-content-center" style="height: 180px;">
              No Cover Image
            </div>
          <% end %>

          <div class="card-body flex-grow-1">

            <h5 class="card-title mb-1 text-truncate">
              <%= book.title %>
            </h5>

            <!-- OWNER BADGE -->
            <% if user_signed_in? && book.user_id == current_user.id %>
              <span class="badge bg-primary mb-2">My Book</span>
            <% end %>

            <p class="mb-2">
              <span class="text-success fw-bold fs-6">
                <%= number_to_currency(book.price) %>
              </span>
            </p>

            <p class="card-text text-muted small">
              <%= truncate(book.description, length: 120) %>
            </p>

            <ul class="list-unstyled small mb-0">
              <li><strong>Author:</strong> <%= book.author %></li>
              <li><strong>Genre:</strong> <%= book.genre %></li>
              <li>
                <strong>Sold:</strong>
                <span class="badge bg-secondary">
                  <%= book.total_purchases %>
                </span>
              </li>
            </ul>

          </div>

          <!-- ACTION BUTTONS FOOTER -->
          <div class="card-footer bg-light mt-auto">
            
            <!-- ROW 1: Main Actions (View & Add to Cart) -->
            <div class="d-flex gap-2 mb-2">
              <!-- View Button -->
              <%= link_to "View", book, class: "btn btn-outline-primary btn-sm flex-grow-1" %>

              <!-- Add to Cart Button (Hidden if it's your own book) -->
              <% if user_signed_in? && book.user_id != current_user.id %>
                <%= button_to 'Add To Cart', line_items_path(book_id: book.id), 
                      method: :post, 
                      class: "btn btn-success btn-sm flex-grow-1" %>
              <% end %>
            </div>

            <!-- ROW 2: Owner Actions (Edit & Delete) -->
            <% if user_signed_in? && book.user_id == current_user.id %>
              <div class="d-flex gap-2">
                <%= link_to "Edit", edit_book_path(book), class: "btn btn-warning btn-sm w-100" %>
                <%= button_to "Delete", book, method: :delete, 
                      data: { confirm: "Are you sure?" }, 
                      class: "btn btn-outline-danger btn-sm w-100" %>
              </div>
            <% end %>
          </div>

        </div>
      </div>
    <% end %>

  </div>
</div>