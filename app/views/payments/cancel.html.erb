<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card text-center shadow-lg border-0">
        <div class="card-body p-5">

          <div class="mb-4">
            <span class="display-1 text-danger">✕</span>
          </div>

          <h2 class="text-danger mb-3">Payment Cancelled</h2>

          <p class="text-muted">
            Your payment was cancelled or did not complete.
            You can try again if you wish to purchase the book.
          </p>

          <hr>

          <div class="d-grid gap-2 mt-4">
            <%= link_to "Try Again", books_path, class: "btn btn-danger btn-lg" %>
            <%= link_to "Back to Books", books_path, class: "btn btn-outline-secondary" %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>